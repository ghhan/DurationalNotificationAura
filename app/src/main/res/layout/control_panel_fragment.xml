<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent"
        android:layout_height="360dp" tools:layout_editor_absoluteY="81dp">
    <Spinner
            android:id="@+id/packageNameSpinner"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="@color/colorSpinnerBG"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    <Button
            android:text="@string/button_trigger"
            android:textSize="12sp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:id="@+id/triggerButton"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/interactButton"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="8dp" app:layout_constraintTop_toBottomOf="@+id/lineChart"/>
    <Button
            android:text="@string/button_interact"
            android:textSize="12sp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:id="@+id/interactButton"
            app:layout_constraintEnd_toStartOf="@+id/resetButton" android:layout_marginEnd="4dp"
            app:layout_constraintStart_toEndOf="@+id/triggerButton" android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp" app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="8dp" app:layout_constraintTop_toBottomOf="@+id/lineChart"/>
    <Button
            android:text="@string/button_reset"
            android:textSize="12sp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:id="@+id/resetButton"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="4dp"
            app:layout_constraintEnd_toStartOf="@+id/resetAllButton"
            app:layout_constraintStart_toEndOf="@+id/interactButton" android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="8dp" app:layout_constraintTop_toBottomOf="@+id/lineChart"/>
    <Button
            android:text="@string/button_resetAll"
            android:textSize="12sp"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:id="@+id/resetAllButton"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/resetButton" android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="8dp" app:layout_constraintTop_toBottomOf="@+id/lineChart"/>
    <TextView
            android:text="@string/status_default"
            android:layout_width="match_parent"
            android:layout_height="116dp"
            android:id="@+id/statusView"
            android:background="@color/colorSpinnerBG"
            android:layout_marginTop="4dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@+id/packageNameSpinner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
    />
    <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="156dp"
            android:layout_marginTop="4dp" app:layout_constraintTop_toBottomOf="@+id/statusView"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="8dp" android:layout_marginEnd="8dp"/>
    <Spinner
            android:layout_width="385dp"
            android:layout_height="wrap_content"
            android:id="@+id/chartSpinner" app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" app:layout_constraintBottom_toBottomOf="@+id/statusView"/>

</android.support.constraint.ConstraintLayout>