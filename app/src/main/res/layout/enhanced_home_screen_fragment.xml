<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/enhancedhomescreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.enhancedhomescreen.EnhancedHomeScreenFragment">
    <GridLayout
            android:id="@+id/gridLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="2"
        >
        <kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup
                android:id="@+id/testViewGroup1"
                android:background="#00000000"
                android:layout_width="150dp"
                android:layout_height="150dp"
        />
        <kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup
                android:id="@+id/testViewGroup2"
                android:background="#00000000"
                android:layout_width="150dp"
                android:layout_height="150dp"
        />
        <kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup
                android:id="@+id/testViewGroup3"
                android:background="#00000000"
                android:layout_width="100dp"
                android:layout_height="100dp"
        />
        <kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup
                android:id="@+id/testViewGroup4"
                android:background="#00000000"
                android:layout_width="100dp"
                android:layout_height="100dp"
        />
        <kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup
                android:id="@+id/testViewGroup5"
                android:background="#00000000"
                android:layout_width="100dp"
                android:layout_height="100dp"
        />

    </GridLayout>

</android.support.constraint.ConstraintLayout>
