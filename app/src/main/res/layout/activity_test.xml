<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".TestActivity">
    <kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup
            android:id="@+id/testViewGroup1"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:minWidth="10dp"
            android:minHeight="10dp"
            android:clipChildren="true"
            android:background="#3300FF00" android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="8dp" android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/testViewGroup2">
    </kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup>
    <kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup
            android:id="@+id/testViewGroup2"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:minWidth="10dp"
            android:minHeight="10dp"
            android:clipChildren="true"
            android:background="#3300FF00" android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="8dp" app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="8dp" app:layout_constraintTop_toTopOf="parent"
    >
    </kr.ac.snu.hcil.durationalnotificationaura.TestViewGroup>

</android.support.constraint.ConstraintLayout>